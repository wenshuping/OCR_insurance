WECHAT_H5_APP_SECRET=""

# SMS delivery mode: mock | real | hybrid
# Production defaults to real when NODE_ENV=production.
SMS_MODE="real"
SMS_REAL_PROVIDER="aliyun"

# Aliyun SMS direct delivery.
ALIYUN_SMS_ACCESS_KEY_ID=""
ALIYUN_SMS_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""
ALIYUN_SMS_TEMPLATE_PARAM_KEY="code"
ALIYUN_SMS_ENDPOINT="dysmsapi.aliyuncs.com"

# Optional webhook relay delivery.
SMS_REAL_WEBHOOK_URL=""
SMS_REAL_WEBHOOK_TIMEOUT_MS="10000"
SMS_REAL_WEBHOOK_AUTH_MODE="none"
SMS_REAL_WEBHOOK_AUTH_HEADER="x-sms-token"
SMS_REAL_WEBHOOK_TOKEN=""
SMS_REAL_SIGN_NAME=""
SMS_REAL_TEMPLATE_ID=""

# Development only. Do not enable mock in production unless explicitly needed.
SMS_MOCK_CODE="123456"
SMS_TEST_MOBILES=""
SMS_ALLOW_MOCK_IN_PRODUCTION="false"

# Feishu Base sync for local product knowledge records.
# Leave base/table empty on first run to let `npm run sync:feishu-knowledge` create them.
