# Copy to deploy/autodl-ocr.env on the AutoDL GPU host and fill real values there.
# Do not commit or paste production secrets.

NODE_ENV=production
OCR_SERVICE_HOST=0.0.0.0
OCR_SERVICE_PORT=4105
POLICY_OCR_CONFIG_PATH=/data/policy-ocr-config.json
POLICY_OCR_SERVICE_TOKEN=

# Choose one provider on the AutoDL host.
#
# 1) Pure OCR / PaddleOCR boxes:
# POLICY_OCR_PROVIDER=paddle_local
# POLICY_OCR_PADDLE_PYTHON=/root/miniconda3/bin/python
# POLICY_OCR_PADDLE_PIPELINE=ocr
#
# 2) GPU vision model on the same AutoDL host:
# POLICY_OCR_PROVIDER=remote_gpu_vision
# POLICY_OCR_REMOTE_VISION_BASE_URL=http://127.0.0.1:8000
# POLICY_OCR_REMOTE_VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct-FP8

POLICY_OCR_PROVIDER=paddle_local
POLICY_OCR_REMOTE_VISION_TIMEOUT_MS=180000
POLICY_OCR_REMOTE_VISION_MAX_IMAGE_DIMENSION=768
POLICY_OCR_REMOTE_VISION_JPEG_QUALITY=85
POLICY_OCR_REMOTE_VISION_MAX_TOKENS=1536
