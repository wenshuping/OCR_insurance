# Copy to deploy/poptonic.env on the ECS host and fill real values there.
# Do not commit or paste production secrets.

POLICY_ADMIN_PASSWORD=
POLICY_OCR_SERVICE_TOKEN=

# OCR service runtime.
# baidu_private is the safest Linux/ECS option unless PaddleOCR/Python is installed in the runtime image.
POLICY_OCR_PROVIDER=baidu_private
POLICY_OCR_SERVICE_TIMEOUT_MS=180000
POLICY_OCR_BAIDU_PRIVATE_URL=
POLICY_OCR_BAIDU_PRIVATE_ACCESS_TOKEN=
POLICY_OCR_BAIDU_PRIVATE_AUTH_MODE=query
POLICY_OCR_BAIDU_PRIVATE_AUTH_HEADER=X-Auth-Token

# Insurance responsibility analysis.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=

# SMS delivery. Use real in production when Aliyun SMS values are configured.
SMS_MODE=real
SMS_REAL_PROVIDER=aliyun
SMS_ALLOW_MOCK_IN_PRODUCTION=false
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_TEMPLATE_PARAM_KEY=code
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
