# Copy to deploy/poptonic.env on the ECS host and fill real values there.
# Do not commit or paste production secrets.

POLICY_ADMIN_PASSWORD=
POLICY_OCR_SERVICE_TOKEN=
POLICY_OCR_SERVICE_URL=https://YOUR_AUTODL_OCR_HOST
POLICY_OCR_SERVICE_TIMEOUT_MS=600000

# OCR runs on the AutoDL GPU host. ECS should not run a local OCR container.
# Keep POLICY_OCR_SERVICE_TOKEN identical on ECS and AutoDL.

# Insurance responsibility analysis and family sales review.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=
DEEPSEEK_FAMILY_REVIEW_MODEL=deepseek-v4-pro
DEEPSEEK_FAMILY_REVIEW_TIMEOUT_MS=600000
DEEPSEEK_FAMILY_REVIEW_MAX_TOKENS=16000

# WeChat H5 identity and JSAPI payment for annual membership.
WECHAT_H5_APP_ID=
WECHAT_H5_APP_SECRET=
WECHAT_PAY_MODE=live
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PLATFORM_PUBLIC_KEY=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_ID=
WECHAT_PAY_NOTIFY_URL=https://ocr.joyhive.cn/api/membership/wechatpay/notify
WECHAT_PAY_ALLOW_MOCK_IN_PRODUCTION=false

# SMS delivery. Use real in production when Aliyun SMS values are configured.
SMS_MODE=real
SMS_REAL_PROVIDER=aliyun
SMS_ALLOW_MOCK_IN_PRODUCTION=false
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_TEMPLATE_PARAM_KEY=code
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
